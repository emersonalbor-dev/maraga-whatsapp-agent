# Maraga WhatsApp Agent — Variables de entorno
# Copia como .env y llena tus datos:
#   cp .env.example .env
# NUNCA subas .env a GitHub.

# ── Anthropic API ─────────────────────────────────────────
ANTHROPIC_API_KEY=

# ── Proveedor de WhatsApp ─────────────────────────────────
WHATSAPP_PROVIDER=twilio

# ── Twilio ────────────────────────────────────────────────
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=+14155238886

# ── Servidor ──────────────────────────────────────────────
PORT=8000
ENVIRONMENT=development

# ── Base de datos ─────────────────────────────────────────
DATABASE_URL=sqlite+aiosqlite:///./maraga-agent.db
# En Railway (PostgreSQL):
# DATABASE_URL=postgresql+asyncpg://user:pass@host:5432/dbname

# ── Directores (números autorizados para queries internas) ─
# Separados por coma, sin espacios, con código de país
DIRECTOR_PHONES=
